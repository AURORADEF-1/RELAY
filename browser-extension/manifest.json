{
  "manifest_version": 3,
  "name": "RELAY Operations Assistant",
  "version": "1.3.0",
  "description": "Receive RELAY admin alerts and search supplier websites using selected catalogue part numbers.",
  "permissions": [
    "activeTab",
    "notifications",
    "scripting",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "RELAY Operations Assistant",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://relay-ryoz.vercel.app/*",
        "https://relay-auroradef-1s-projects.vercel.app/*",
        "https://relay-git-main-auroradef-1s-projects.vercel.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "relay-bridge.js"
      ],
      "run_at": "document_start"
    }
  ]
}
